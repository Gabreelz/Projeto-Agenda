<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">

      <div class="text-center mb-5">
        <h2 class="fw-bold">Acesse sua conta</h2>
        <p class="text-muted">Entre ou crie sua conta para continuar</p>
      </div>

      <%- include('includes/messages') %>

      <div class="row g-4">

        <!-- CADASTRO -->
        <div class="col-md-6">
          <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-body p-4">

              <h4 class="fw-bold mb-3">Criar conta</h4>
              <p class="text-muted mb-4">
                Ainda não tem cadastro? Crie sua conta abaixo.
              </p>

              <form action="/login/register" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="form-floating mb-3">
                  <input 
                    id="register-email"
                    type="email" 
                    class="form-control rounded-3" 
                    name="email"
                    placeholder="Email"
                    autocomplete="email"
                    required>
                  <label for="register-email">Email</label>
                </div>

                <div class="form-floating mb-4">
                  <input 
                    id="register-password"
                    type="password" 
                    class="form-control rounded-3" 
                    name="password"
                    placeholder="Senha"
                    autocomplete="new-password"
                    required>
                  <label for="register-password">Senha</label>
                </div>

                <div class="d-grid">
                  <button type="submit" class="btn btn-success btn-lg rounded-3">
                    Criar conta
                  </button>
                </div>
              </form>

            </div>
          </div>
        </div>

        <!-- LOGIN -->
        <div class="col-md-6">
          <div class="card shadow-lg border-0 rounded-4 h-100">
            <div class="card-body p-4">

              <h4 class="fw-bold mb-3">Entrar</h4>
              <p class="text-muted mb-4">
                Já possui uma conta? Faça login.
              </p>

              <form action="/login/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="form-floating mb-3">
                  <input 
                    id="login-email"
                    type="email" 
                    class="form-control rounded-3" 
                    name="email"
                    placeholder="Email"
                    autocomplete="email"
                    required>
                  <label for="login-email">Email</label>
                </div>

                <div class="form-floating mb-4">
                  <input 
                    id="login-password"
                    type="password" 
                    class="form-control rounded-3" 
                    name="password"
                    placeholder="Senha"
                    autocomplete="current-password"
                    required>
                  <label for="login-password">Senha</label>
                </div>

                <div class="d-grid">
                  <button type="submit" class="btn btn-primary btn-lg rounded-3">
                    Entrar
                  </button>
                </div>
              </form>

            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('includes/footer') %>