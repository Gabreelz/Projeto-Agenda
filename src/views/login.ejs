<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-3">
      <h1 class="text-center">Criar conta ou Entrar</h1>
      <p class="text-center lead">Faça login ou crie sua conta abaixo</p>

      <%- include('includes/messages') %>

      <div class="row">

        <!-- CADASTRO -->
        <div class="col-lg">
          <h4>Faça seu cadastro</h4>
          <p>Se você ainda não tem conta, preencha o formulário abaixo:</p>

          <form action="/login/register" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="form-group">
              <label for="register-email">Seu e-mail</label>
              <input 
                id="register-email"
                type="email" 
                class="form-control" 
                name="email"
                autocomplete="email"
                required>
            </div>

            <div class="form-group">
              <label for="register-password">Sua senha</label>
              <input 
                id="register-password"
                type="password" 
                class="form-control" 
                name="password"
                autocomplete="new-password"
                required>
            </div>

            <button type="submit" class="btn btn-primary">
              Criar conta
            </button>
          </form>
        </div>

        <!-- LOGIN -->
        <div class="col-lg">
          <h4>Faça seu login</h4>
          <p>Se você já tem uma conta, faça login abaixo:</p>

          <form action="/login/login" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="form-group">
              <label for="login-email">Seu e-mail</label>
              <input 
                id="login-email"
                type="email" 
                class="form-control" 
                name="email"
                autocomplete="email"
                required>
            </div>

            <div class="form-group">
              <label for="login-password">Sua senha</label>
              <input 
                id="login-password"
                type="password" 
                class="form-control" 
                name="password"
                autocomplete="current-password"
                required>
            </div>

            <button type="submit" class="btn btn-primary">
              Entrar
            </button>
          </form>
        </div>

      </div>
    </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer') %>