<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Cabeçalho -->
      <div class="text-center mb-5">
        <h1 class="fw-bold display-6">📒 Agenda</h1>
        <p class="text-muted">Gerencie seus contatos cadastrados</p>
      </div>

      <%- include('includes/messages') %>

      <% if (!contatos || contatos.length === 0) { %>

        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body text-center py-5">
            <h5 class="mb-3">Nenhum contato cadastrado</h5>
            <p class="text-muted">
              Comece adicionando seu primeiro contato.
            </p>
          </div>
        </div>

      <% } else { %>

        <% contatos.forEach(contato => { %>

          <div class="card shadow-sm border-0 mb-3 rounded-4 hover-card">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

              <!-- Dados -->
              <div class="mb-2 mb-md-0">
                <h5 class="mb-1 fw-semibold">
                  <%= contato.nome %> <%= contato.sobrenome %>
                </h5>
                <small class="text-muted d-block">
                  📧 <%= contato.email %>
                </small>
                <small class="text-muted">
                  📱 <%= contato.telefone %>
                </small>
              </div>

              <!-- Botões como estavam -->
              <div class="d-flex gap-2">
                <a href="/contato/edit/<%= contato._id %>" 
                   class="btn btn-outline-primary btn-sm rounded-pill px-3">
                  Editar
                </a>

                <a href="/contato/delete/<%= contato._id %>" 
                   class="btn btn-outline-danger btn-sm rounded-pill px-3">
                  Excluir
                </a>
              </div>

            </div>
          </div>

        <% }); %>

      <% } %>

    </div>
  </div>
</div>

<%- include('includes/footer') %>